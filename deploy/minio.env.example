# MinIO credentials for the docker-compose service AND the TaskTrack app.
#
# Copy to deploy/minio.env and fill in real values:
#   cp deploy/minio.env.example deploy/minio.env
#   # generate creds:
#   echo "MINIO_ROOT_USER=tasktrack" >> deploy/minio.env
#   echo "MINIO_ROOT_PASSWORD=$(openssl rand -base64 32)" >> deploy/minio.env
#
# deploy/minio.env is gitignored. The collab-tracker user systemd unit
# loads the same file (EnvironmentFile=-) so the Flask app sees the
# matching credentials and bucket name.

# --- MinIO container root credentials ---
MINIO_ROOT_USER=tasktrack
MINIO_ROOT_PASSWORD=change-me-before-first-boot

# --- TaskTrack client config (what the Flask app reads) ---
# Endpoint must be reachable from the gunicorn process. 127.0.0.1 is
# correct when MinIO runs on the same host.
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=tasktrack
MINIO_SECRET_KEY=change-me-before-first-boot
MINIO_BUCKET=tasktrack-attachments
# Region is cosmetic for MinIO but boto3 demands one.
MINIO_REGION=us-east-1
