# Local override for TaskTrack scoped API tokens.
#
# Copy to deploy/tokens.env and fill in real values. The collab-tracker
# user systemd unit loads this file (EnvironmentFile=-) so the Flask
# app sees the tokens.
#
# Preferred long-term home is the Bitwarden 'TaskTrack' vault item that
# nexus-svc-inject pulls from on service start; this file is for tokens
# that haven't been moved there yet.

TASKTRACK_TOKEN_INBOX=__SET_ME__
